# Copy this file to .env and fill in values before running with LLM enabled.

# LLM provider: openai or gemini or groq
LLM_PROVIDER=openai

# OpenAI provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini provider
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Groq provider
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Optional LLM settings
LLM_TIMEOUT_SECONDS=10
LLM_MIN_INTERVAL_SECONDS=0.25

# Streamlit settings
STREAMLIT_SERVER_PORT=8501